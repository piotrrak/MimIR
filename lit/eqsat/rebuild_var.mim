// RUN: sed 's/__IMPL__/egg/' %s > %t && %mim %t -o -
// RUN: sed 's/__IMPL__/slotted/' %s > %t && %mim %t -o -

plugin core;
plugin eqsat;

fun extern _impl(): %eqsat.Impl =
    return %eqsat.__IMPL__;

fun extern test(cond: Bool, a: «3; I32», b: «3; I32», i: Idx 3): «3; I32» =
    con nx(phi: «3; I32») = return ins(phi, i, 23I32);
    (cn () = nx a, cn () = nx b)#cond ();
