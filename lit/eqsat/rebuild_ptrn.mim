// RUN: sed 's/__IMPL__/egg/' %s > %t && %mim %t -o -
// RUN: sed 's/__IMPL__/slotted/' %s > %t && %mim %t -o -

plugin core;
plugin eqsat;

fun extern _impl(): %eqsat.Impl =
    return %eqsat.__IMPL__;

lam PtrN(n: Nat, T: *): * = (PtrN (%core.nat.sub (n, 1), %mem.Ptr0 T), T)#(%core.ncmp.e (n, 0));

fun extern foo(mem: %mem.M 0, p: PtrN (4, I32)): [%mem.M 0, PtrN (3, I32)] = return (%mem.load (mem, p));
